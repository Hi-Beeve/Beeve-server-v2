generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model daily_recommendation {
  recommendation_id             BigInt                          @id @default(autoincrement())
  member_id                     BigInt
  total_duration                Int?                            @db.SmallInt
  rpe                           Int?                            @db.SmallInt
  recommendation_date           DateTime                        @default(now()) @db.Timestamptz(6)
  target_fitness_type           String?                         @db.VarChar
  ai_prompt                     String?
  ai_response                   String?
  status                        String?                         @db.VarChar
  deleted_yn                    String?                         @db.VarChar
  member                        member                          @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction, map: "recommend_schedule_member_id_fkey")
  daily_recommendation_exercise daily_recommendation_exercise[]
  recommendation_feedback       recommendation_feedback[]

  @@unique([member_id, recommendation_date], map: "uq_member_recommendation_date")
}

model daily_recommendation_exercise {
  recommendation_exercise_id BigInt               @id @default(autoincrement())
  recommendation_id          BigInt
  exercise_name              String               @db.VarChar
  reps                       Int?                 @db.SmallInt
  sets                       Int?                 @db.SmallInt
  rest_seconds               Int?                 @db.SmallInt
  created_at                 DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?            @default(now()) @db.Timestamptz(6)
  exercise_id                BigInt
  duration                   Int?                 @db.SmallInt
  daily_recommendation       daily_recommendation @relation(fields: [recommendation_id], references: [recommendation_id], onDelete: NoAction, onUpdate: NoAction)
  exercise_program           exercise_program     @relation(fields: [exercise_id], references: [exercise_id], onDelete: NoAction, onUpdate: NoAction, map: "recommend_schedule_detail_exercise_id_fkey")
}

model exercise_program {
  exercise_id                   BigInt                          @id @default(autoincrement())
  exercise_name                 String?                         @db.VarChar
  exercise_step                 String?                         @db.VarChar
  equipment                     String?                         @db.VarChar
  caution                       String?                         @db.VarChar
  fitness_type                  String?                         @db.VarChar
  purpose                       String?                         @db.VarChar
  daily_recommendation_exercise daily_recommendation_exercise[]
}

model fitness_measure {
  measure_id     BigInt    @id @default(autoincrement())
  member_id      BigInt?
  age            Int       @db.SmallInt
  age_range      Json
  measure_day    DateTime  @db.Date
  gender         String    @db.VarChar
  height         Decimal?  @db.Decimal
  weight         Decimal?  @db.Decimal
  bmi            Decimal?  @db.Decimal
  fitness_result Json?
  rpe            Int?      @db.SmallInt
  measure_place  String?   @db.VarChar
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  deleted_yn     String?   @default("N") @db.VarChar
  member         member?   @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction)
  @@unique([member_id, measure_day], map: "uq_member_measure_day")
  @@index([measure_day])
  @@index([member_id, measure_day])
}

model member {
  member_id                 BigInt                      @id @default(autoincrement())
  email                     String                      @db.VarChar
  name                      String?                     @db.VarChar
  birth_date                DateTime?                   @db.Date
  gender                    String                      @db.VarChar
  height                    Decimal?                    @db.Decimal
  weight                    Decimal?                    @db.Decimal
  bmi                       Decimal?                    @db.Decimal
  profile_url               String?
  phone_number              String?                     @unique @db.VarChar(20)
  withdraw_reason           String?                     @db.VarChar
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                    @default(now()) @db.Timestamptz(6)
  deleted_yn                String                      @default("N") @db.VarChar
  daily_recommendation      daily_recommendation[]
  fitness_measure           fitness_measure[]
  recommendation_feedback   recommendation_feedback[]
  refresh_token             refresh_token[]
  social_auth               social_auth[]
  user_exercise_information user_exercise_information[]
}


model recommendation_feedback {
  feedback_id          BigInt               @id @default(autoincrement())
  recommendation_id    BigInt
  member_id            BigInt?
  completed_at         DateTime?            @default(now()) @db.Timestamptz(6)
  difficulty_rating    Int?                 @db.SmallInt
  satisfaction_rating  Int?                 @db.SmallInt
  actual_duration      Int?                 @db.SmallInt
  member               member?              @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction)
  daily_recommendation daily_recommendation @relation(fields: [recommendation_id], references: [recommendation_id], onDelete: NoAction, onUpdate: NoAction)
}

model refresh_token {
  refresh_token_id BigInt   @id @default(autoincrement())
  member_id        BigInt
  token            String
  created_at       DateTime @db.Timestamptz(6)
  updated_at       DateTime @db.Timestamptz(6)
  member           member   @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction)
}

model social_auth {
  social_auth_id   BigInt    @id @default(autoincrement())
  member_id        BigInt
  provider         String    @db.VarChar
  provider_user_id String    @db.VarChar
  consent_scope    String?   @db.VarChar
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  deleted_yn       String?   @default("N") @db.VarChar
  member           member    @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction)
}

model user_exercise_information {
  exercise_info_id BigInt    @id(map: "exercise_information_pkey") @default(autoincrement())
  member_id        BigInt
  goal             String    @db.VarChar
  place            String    @db.VarChar
  equipment        String?   @db.VarChar
  disease          String?   @db.VarChar
  injury           String?   @db.VarChar
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  deleted_yn       String?   @default("N") @db.VarChar
  member           member    @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction, map: "exercise_information_member_id_fkey")
}
